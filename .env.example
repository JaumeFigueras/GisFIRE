# GisFIRE environment variables.
#
# Copy this file to `.env` at the repository root and fill in the values:
#
#     cp .env.example .env
#
# `.env` is git-ignored and must never be committed — it holds real credentials.
# This example file is committed and documents every variable the project reads.
# Anything already exported in the real environment takes precedence over `.env`,
# so deployments can ignore the file entirely.
#
# Read by src/settings.py, which Alembic (alembic/env.py), the FastAPI app and
# the import applications all use.

# --- Database (PostgreSQL / PostGIS) ---------------------------------------
# Used to build the SQLAlchemy URL. GISFIRE_DB_NAME and GISFIRE_DB_USER are
# required and have no default; the rest fall back to the values shown.
GISFIRE_DB_HOST=localhost
GISFIRE_DB_PORT=5432
GISFIRE_DB_NAME=gisfire
GISFIRE_DB_USER=gisfire
GISFIRE_DB_PASSWORD=change-me

# --- API server (FastAPI / uvicorn) ----------------------------------------
GISFIRE_API_HOST=127.0.0.1
GISFIRE_API_PORT=8000

# --- Logging ----------------------------------------------------------------
# One of: CRITICAL, ERROR, WARNING, INFO, DEBUG.
GISFIRE_LOG_LEVEL=INFO
